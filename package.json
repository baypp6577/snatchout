{
  "name": "snatchout-event-management",
  "version": "1.0.0",
  "description": "SnatchOut Event Management Website",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server public -a localhost -p 5174 --cors",
    "dev": "npx http-server public -a localhost -p 5174 -o --cors",
    "serve": "npx http-server public -a localhost -p 5174 -o --cors",
    "dev-auto": "npx http-server public -a localhost -o --cors",
    "deploy": "vercel --prod"
  },
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static",
      "config": {
        "distDir": "public"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "files": [
    "dist",
    "public"
  ],
  "keywords": [
    "event",
    "management",
    "snatchout",
    "website"
  ],
  "author": "SnatchOut Team",
  "license": "MIT",
  "devDependencies": {
    "live-server": "^1.2.2",
    "http-server": "^14.1.1"
  }
}
