{
  "name": "snatchout-event-management",
  "version": "1.0.0",
  "description": "Premier Event Management Website",
  "main": "index.html",
  "scripts": {
    "dev": "live-server --port=3000 --host=localhost",
    "build": "npm run minify-html && npm run minify-css && npm run minify-js",
    "minify-html": "html-minifier --collapse-whitespace --remove-comments --remove-optional-tags --minify-css --minify-js index.html -o dist/index.html",
    "minify-css": "cleancss -o dist/styles.min.css src/styles.css",
    "minify-js": "terser src/script.js -o dist/script.min.js",
    "serve": "http-server dist -p 3001",
    "preview": "npm run build && npm run serve"
  },
  "keywords": [
    "events",
    "management",
    "snatchout",
    "eventbrite"
  ],
  "author": "SnatchOut Team",
  "license": "MIT",
  "devDependencies": {
    "live-server": "^1.2.2",
    "html-minifier": "^4.0.0",
    "clean-css-cli": "^5.6.3",
    "terser": "^5.26.0",
    "http-server": "^14.1.1"
  },
  "dependencies": {}
}
